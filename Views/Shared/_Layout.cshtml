<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – UniFleq IMS</title>

    <!-- Google Fonts: Syne (display) + DM Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --sidebar-w: 260px;
            --topbar-h: 64px;
            --bg-main: #f5f5f5;
            --bg-sidebar: #ffffff;
            --bg-card: #ffffff;
            --bg-card-hover: #f9f9f9;
            --border-color: #e0e0e0;
            --accent: #d62a24;
            --accent-light: #e85550;
            --accent-glow: rgba(214,42,36,0.15);
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #38bdf8;
            --text-primary: #1a1a1a;
            --text-secondary: #555555;
            --text-muted: #888888;
            --font-display: 'Syne', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --radius: 12px;
            --radius-sm: 8px;
            --shadow: 0 4px 24px rgba(0,0,0,0.08);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-body);
            background: var(--bg-main);
            color: var(--text-primary);
            font-size: 14px;
            min-height: 100vh;
            display: flex;
        }

        #sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            position: fixed;
            left: 0;
            top: 0;
            display: flex;
            flex-direction: column;
            z-index: 200;
            transition: transform 0.3s ease;
        }

        .sidebar-brand {
            padding: 24px 20px 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .brand-logo {
            font-family: var(--font-display);
            font-size: 22px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }

            .brand-logo span {
                color: var(--accent);
            }

        .brand-tagline {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 2px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .sidebar-nav {
            padding: 16px 0;
            flex: 1;
            overflow-y: auto;
        }

        .nav-section-label {
            font-size: 10px;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 12px 20px 6px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            color: var(--text-secondary);
            text-decoration: none;
            border-radius: 0;
            font-size: 13.5px;
            font-weight: 400;
            transition: all 0.15s ease;
            position: relative;
        }

            .nav-item a:hover {
                color: var(--text-primary);
                background: rgba(255,255,255,0.04);
            }

            .nav-item a.active {
                color: var(--accent-light);
                background: var(--accent-glow);
                font-weight: 500;
            }

                .nav-item a.active::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 0;
                    bottom: 0;
                    width: 3px;
                    background: var(--accent);
                    border-radius: 0 2px 2px 0;
                }

            .nav-item a i {
                font-size: 16px;
                width: 20px;
                text-align: center;
            }

        .sidebar-user {
            padding: 16px 20px;
            border-top: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--accent-glow);
            border: 2px solid var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: var(--accent-light);
            font-weight: 700;
            font-family: var(--font-display);
            flex-shrink: 0;
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 11px;
            color: var(--text-muted);
        }

        #main-wrapper {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        #topbar {
            height: var(--topbar-h);
            background: var(--bg-sidebar);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Hamburger — hidden on desktop */
        #hamburger-btn {
            display: none;
            background: transparent;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 6px 10px;
            cursor: pointer;
            color: var(--text-secondary);
            font-size: 20px;
            line-height: 1;
            transition: all 0.15s;
        }

            #hamburger-btn:hover {
                border-color: var(--accent);
                color: var(--accent);
            }

        .topbar-title {
            font-family: var(--font-display);
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Dark overlay behind sidebar on mobile */
        #sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.45);
            z-index: 150;
        }

            #sidebar-overlay.show {
                display: block;
            }

        #page-content {
            padding: 28px;
            flex: 1;
        }

        .card-uni {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 24px;
            transition: border-color 0.2s;
        }

            .card-uni:hover {
                border-color: #333648;
            }

        .kpi-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.2s;
        }

            .kpi-card:hover {
                border-color: var(--accent);
                box-shadow: 0 0 20px var(--accent-glow);
                transform: translateY(-2px);
            }

        .kpi-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
        }

        .kpi-value {
            font-family: var(--font-display);
            font-size: 26px;
            font-weight: 700;
            line-height: 1;
        }

        .kpi-label {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
            letter-spacing: 0.3px;
        }

        .table-uni {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }

            .table-uni thead th {
                background: #f0f0f0;
                color: var(--text-muted);
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                padding: 10px 14px;
                border-bottom: 1px solid var(--border-color);
                white-space: nowrap;
            }

            .table-uni tbody tr {
                border-bottom: 1px solid var(--border-color);
                transition: background 0.15s;
            }

                .table-uni tbody tr:hover {
                    background: var(--bg-card-hover);
                }

            .table-uni tbody td {
                padding: 12px 14px;
                color: var(--text-primary);
                vertical-align: middle;
            }

        .badge-uni {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0.3px;
        }

        .badge-success {
            background: rgba(34,197,94,0.15);
            color: #22c55e;
        }

        .badge-warning {
            background: rgba(245,158,11,0.15);
            color: #f59e0b;
        }

        .badge-danger {
            background: rgba(239,68,68,0.15);
            color: #ef4444;
        }

        .badge-info {
            background: rgba(56,189,248,0.15);
            color: #38bdf8;
        }

        .badge-purple {
            background: rgba(108,99,255,0.15);
            color: #8b85ff;
        }

        .badge-muted {
            background: rgba(255,255,255,0.06);
            color: var(--text-muted);
        }

        .btn-accent {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 8px 18px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

            .btn-accent:hover {
                background: var(--accent-light);
                box-shadow: 0 0 16px var(--accent-glow);
                color: #fff;
            }

        .btn-ghost {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            cursor: pointer;
            transition: all 0.15s;
        }

            .btn-ghost:hover {
                border-color: var(--accent);
                color: var(--accent-light);
            }

        .form-control-uni, .form-select-uni {
            background: #f5f5f5;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            color: var(--text-primary);
            padding: 9px 14px;
            font-size: 13.5px;
            width: 100%;
            transition: border-color 0.2s;
            font-family: var(--font-body);
        }

            .form-control-uni:focus, .form-select-uni:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-glow);
                background: var(--bg-main);
                color: var(--text-primary);
            }

            .form-control-uni::placeholder {
                color: var(--text-muted);
            }

            .form-select-uni option {
                background: var(--bg-card);
            }

        .form-label-uni {
            font-size: 12px;
            font-weight: 500;
            color: var(--text-secondary);
            margin-bottom: 6px;
            letter-spacing: 0.3px;
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .section-title {
            font-family: var(--font-display);
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .alert-uni {
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            margin-bottom: 16px;
            border: 1px solid;
        }

        .alert-success {
            background: rgba(34,197,94,0.1);
            border-color: rgba(34,197,94,0.3);
            color: #22c55e;
        }

        .alert-danger {
            background: rgba(239,68,68,0.1);
            border-color: rgba(239,68,68,0.3);
            color: #ef4444;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 3px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #333648;
            }

        /* ── MOBILE ── */
        @@media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
                height: 100vh;
                overflow-y: auto;
            }

                #sidebar.open {
                    transform: translateX(0);
                    box-shadow: 4px 0 24px rgba(0,0,0,0.2);
                }

            #main-wrapper {
                margin-left: 0;
            }

            #hamburger-btn {
                display: block;
            }

            #topbar {
                padding: 0 16px;
                position: sticky;
                top: 0;
                z-index: 100;
            }

            #page-content {
                padding: 16px;
            }

            .topbar-title {
                font-size: 15px;
            }
            /* Lock body scroll when sidebar is open */
            body.sidebar-open {
                overflow: hidden;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Overlay: tap to close sidebar on mobile -->
        <div id="sidebar-overlay"></div>

        <nav id="sidebar">
            <div class="sidebar-brand">
                <div class="brand-logo">Uni<span>Fleq</span></div>
                <div class="brand-tagline">Inventory Management System</div>
            </div>

            <div class="sidebar-nav">

                <!-- MAIN — all roles -->
                <div class="nav-section-label">Main</div>
                <div class="nav-item">
                    <a href="@Url.Action("Index","Dashboard")"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Dashboard" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </div>

                <!-- INVENTORY -->
                @if (User.IsInRole("Admin") || User.IsInRole("InventoryManager") || User.IsInRole("InventoryClerk") || User.IsInRole("Auditor"))
                {
                    <div class="nav-section-label" style="margin-top:8px">Inventory</div>

                    <div class="nav-item">
                        <a href="@Url.Action("Index","Inventory")"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Inventory" ? "active" : "")">
                            <i class="bi bi-boxes"></i> Stock Monitor
                        </a>
                    </div>

                    @if (User.IsInRole("Admin") || User.IsInRole("InventoryManager") || User.IsInRole("InventoryClerk"))
                    {
                        <div class="nav-item">
                            <a href="@Url.Action("Index","StockAdjustment")"
                               class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="StockAdjustment" ? "active" : "")">
                                <i class="bi bi-arrow-left-right"></i> Stock Adjustment
                            </a>
                        </div>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("InventoryManager") || User.IsInRole("Auditor"))
                    {
                        <div class="nav-item">
                            <a href="@Url.Action("Valuation","Inventory")"
                               class="@(ViewContext.RouteData.Values["action"]?.ToString()=="Valuation" ? "active" : "")">
                                <i class="bi bi-bar-chart-line-fill"></i> Valuation Report
                            </a>
                        </div>
                    }
                }

                <!-- CATALOG -->
                @if (User.IsInRole("Admin") || User.IsInRole("InventoryManager"))
                {
                    <div class="nav-section-label" style="margin-top:8px">Catalog</div>
                    <div class="nav-item">
                        <a href="@Url.Action("Index","Product")"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Product" ? "active" : "")">
                            <i class="bi bi-cpu-fill"></i> Products
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="@Url.Action("Index","Category")"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Category" ? "active" : "")">
                            <i class="bi bi-tag-fill"></i> Categories
                        </a>
                    </div>
                }

                <!-- PROCUREMENT -->
                @if (User.IsInRole("Admin") || User.IsInRole("ProcurementStaff") || User.IsInRole("InventoryManager"))
                {
                    <div class="nav-section-label" style="margin-top:8px">Procurement</div>
                    <div class="nav-item">
                        <a href="@Url.Action("Index","PurchaseOrder")"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="PurchaseOrder" ? "active" : "")">
                            <i class="bi bi-cart-check-fill"></i> Purchase Orders
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="@Url.Action("Index","Supplier")"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Supplier" ? "active" : "")">
                            <i class="bi bi-building"></i> Suppliers
                        </a>
                    </div>
                }

                <!-- ADMINISTRATION -->
                @if (User.IsInRole("Admin") || User.IsInRole("Auditor"))
                {
                    <div class="nav-section-label" style="margin-top:8px">Administration</div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="nav-item">
                            <a href="@Url.Action("Index","User")"
                               class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="User" ? "active" : "")">
                                <i class="bi bi-people-fill"></i> User Accounts
                            </a>
                        </div>
                    }

                    <div class="nav-item">
                        <a href="@Url.Action("Index","AuditLog")"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="AuditLog" ? "active" : "")">
                            <i class="bi bi-journal-text"></i> Audit Logs
                        </a>
                    </div>
                }

            </div>

            <div class="sidebar-user">
                <div class="user-avatar">
                    @(User.FindFirst("FullName")?.Value?.Substring(0, 1).ToUpper() ?? "U")
                </div>
                <div class="user-info">
                    <div class="user-name">@User.FindFirst("FullName")?.Value</div>
                    <div class="user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
            </div>
        </nav>

        <div id="main-wrapper">
            <header id="topbar">
                <div class="topbar-left">
                    <!-- Hamburger — only shows on mobile -->
                    <button id="hamburger-btn" onclick="toggleSidebar()">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</div>
                </div>
                <div class="topbar-right">
                    @if (TempData["Success"] != null)
                    {
                        <span class="badge-uni badge-success">✓ @TempData["Success"]</span>
                    }
                    <form method="post" action="@Url.Action("Logout","Account")" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-ghost">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                </div>
            </header>

            <main id="page-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <!-- jQuery (must load first) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>

    <!-- jQuery Validation -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSidebar() {
            var sidebar = document.getElementById('sidebar');
            var overlay = document.getElementById('sidebar-overlay');
            if (sidebar.classList.contains('open')) {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
                document.body.classList.remove('sidebar-open');
            } else {
                sidebar.classList.add('open');
                overlay.classList.add('show');
                document.body.classList.add('sidebar-open');
            }
        }

        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebar-overlay').classList.remove('show');
            document.body.classList.remove('sidebar-open');
        }

        // Tap overlay to close
        var overlay = document.getElementById('sidebar-overlay');
        if (overlay) {
            overlay.addEventListener('click', function () { closeSidebar(); });
        }

        // Tap nav link on mobile to close
        document.querySelectorAll('.nav-item a').forEach(function (link) {
            link.addEventListener('click', function () {
                if (window.innerWidth <= 768) { closeSidebar(); }
            });
        });

        // Global toast helper
        window.showToast = function (msg, type) {
            type = type || 'success';
            var div = document.createElement('div');
            div.className = 'alert-uni alert-' + type;
            div.style.cssText = 'position:fixed;top:80px;right:24px;z-index:9999;min-width:280px;box-shadow:0 8px 32px rgba(0,0,0,0.5)';
            div.textContent = msg;
            document.body.appendChild(div);
            setTimeout(function () { div.remove(); }, 4000);
        };
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
