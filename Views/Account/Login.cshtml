@model UnifleqSolutions_IMS.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – UniFleq IMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/login.css" />
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <style>
        /* reCAPTCHA */
        .recaptcha-wrap {
            width: 100%;
            margin: 16px 0;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

            .recaptcha-wrap .g-recaptcha {
                transform: scale(0.92);
                transform-origin: center center;
            }
    </style>
</head>
<body>
    <div class="login-box">
        <div style="font-family:'Syne',sans-serif;font-size:28px;font-weight:800;
            color:#1C1C1C;text-align:center;margin-top:12px">
            Uni<span style="color:#d62a24">Fleq</span>
        </div>
        <div class="divider"></div>
        <p class="login-subtitle">Inventory Management System</p>

        @if (!ViewData.ModelState.IsValid)
        {
            foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="alert-danger">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    @error.ErrorMessage
                </div>
            }
        }

        <form method="post" asp-action="Login" asp-controller="Account" style="width:100%">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form-group">
                <label class="form-label-uni">Username</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-person"></i>
                    <input asp-for="Username" class="form-control-uni"
                           placeholder="Enter your username" autocomplete="username" />
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label-uni">Password</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" type="password" class="form-control-uni"
                           placeholder="Enter your password" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="recaptcha-wrap" style="display:flex;justify-content:center;margin:16px 0">
                <div class="g-recaptcha" data-sitekey="@ViewData["ReCaptchaSiteKey"]"></div>
            </div>

            <button type="submit" class="login-btn">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>
        </form>
    </div>
</body>
</html>